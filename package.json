{
  "name": "citations-db",
  "version": "1.0.0",
  "description": "Ground-truth citation database to prevent hallucinated references",
  "type": "module",
  "scripts": {
    "validate": "bun run scripts/cite.ts validate",
    "lookup": "bun run scripts/cite.ts lookup",
    "search": "bun run scripts/cite.ts search",
    "tags": "bun run scripts/cite.ts tags",
    "bibtex": "bun run scripts/cite.ts bibtex",
    "add-arxiv": "bun run scripts/add-arxiv.ts",
    "add-clawxiv": "bun run scripts/add-clawxiv.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "citations",
    "references",
    "bibliography",
    "research"
  ],
  "author": "Jordan",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "typescript": "^5.0.0"
  }
}
